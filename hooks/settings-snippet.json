{
  "_comment": "A FUSIONNER dans %USERPROFILE%\\.claude\\settings.json de chaque poste (NE PAS ecraser le fichier : ajouter ces entrees aux tableaux hooks existants, ou creer le bloc hooks s'il manque). Chemins portables via $env:USERPROFILE. Miroir fidele du settings.json live. Apres fusion : /hooks ou redemarrer Claude Code pour recharger.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/model-tier.ps1\"",
            "shell": "powershell",
            "statusMessage": "Model tiering (Explore/general-purpose -> sonnet)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/anti-flaky.ps1\"",
            "shell": "powershell",
            "statusMessage": "Anti-flaky (sleep brut ?)"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/fix-gate.ps1\"",
            "shell": "powershell",
            "statusMessage": "Fix-gate (blind-fix loop ?)"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/full-autonomy-allow.ps1\"",
            "shell": "powershell",
            "statusMessage": "Full-autonomy allow (opt-in: AUTOWIN_AUTONOMY=1)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/build-cadence.ps1\"",
            "shell": "powershell",
            "statusMessage": "Build cadence (verify each increment ?)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/judge-nudge.ps1\"",
            "shell": "powershell",
            "statusMessage": "judge nudge"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/kaizen-revert-log.ps1\"",
            "shell": "powershell",
            "statusMessage": "Kaizen revert-log (fix rate ?)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/stop-gate.ps1\"",
            "shell": "powershell",
            "statusMessage": "Stop-gate (run ouvert non-vert ?)"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/kaizen-nudge.ps1\"",
            "shell": "powershell",
            "statusMessage": "Kaizen (pattern d'echec recurrent ?)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/precompact-runcheck.ps1\"",
            "shell": "powershell",
            "statusMessage": "PreCompact (open RUN ?)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/thinking-mode.ps1\"",
            "shell": "powershell",
            "statusMessage": "Thinking mode (?)"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/session-inject.ps1\"",
            "shell": "powershell",
            "statusMessage": "Inject session_id (scope workspaces)"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/advisory-guard.ps1\"",
            "shell": "powershell",
            "statusMessage": "Advisory-guard (reponds direct, pas pipeline ?)"
          },
          {
            "type": "command",
            "command": "& \"$env:USERPROFILE/.claude/hooks/full-autonomy-directive.ps1\"",
            "shell": "powershell",
            "statusMessage": "Full-autonomy directive (opt-in: AUTOWIN_AUTONOMY=1)"
          }
        ]
      }
    ]
  }
}
